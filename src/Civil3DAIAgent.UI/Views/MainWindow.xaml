<Window x:Class="Civil3DAIAgent.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Civil3D AI Agent — Road Design Automation"
        Height="720" Width="1040" MinHeight="560" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="12">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="Button" x:Key="Browse">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- inputs -->
            <RowDefinition Height="*"/>      <!-- steps + log -->
            <RowDefinition Height="Auto"/>   <!-- progress -->
            <RowDefinition Height="Auto"/>   <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Civil3D AI Agent" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="  •  automated road design (first 3 km → alignment → corridor → sheets → PDF)"
                       VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>

        <!-- Inputs -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Input DWG:" Style="{StaticResource Label}"/>
            <TextBox   Grid.Row="0" Grid.Column="1" Margin="0,3" Padding="4,3"
                       Text="{Binding InputDwgPath, UpdateSourceTrigger=PropertyChanged}"/>
            <Button    Grid.Row="0" Grid.Column="2" Content="Browse…" Style="{StaticResource Browse}"
                       Command="{Binding BrowseDwgCommand}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Input Excel:" Style="{StaticResource Label}"/>
            <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,3" Padding="4,3"
                       Text="{Binding InputExcelPath, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="Optional. Survey points to add to the existing-ground surface."/>
            <Button    Grid.Row="1" Grid.Column="2" Content="Browse…" Style="{StaticResource Browse}"
                       Command="{Binding BrowseExcelCommand}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Output folder:" Style="{StaticResource Label}"/>
            <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,3" Padding="4,3"
                       Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"/>
            <Button    Grid.Row="2" Grid.Column="2" Content="Browse…" Style="{StaticResource Browse}"
                       Command="{Binding BrowseOutputCommand}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Extract length (m):" Style="{StaticResource Label}"/>
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                <TextBox Width="120" Margin="0,3" Padding="4,3"
                         Text="{Binding SegmentLengthMeters, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="(0 uses appsettings.json)" VerticalAlignment="Center"
                           Margin="10,0,0,0" Foreground="Gray"/>
                <TextBlock Text="Run up to step (debug):" VerticalAlignment="Center"
                           Margin="24,0,4,0" FontWeight="SemiBold" Foreground="#B00"/>
                <TextBox Width="50" Margin="0,3" Padding="4,3"
                         Text="{Binding MaxStep, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="0 = all 23 steps. Set 1, then 2, 3… to isolate a crashing step."/>
                <TextBlock Text="(0 = all)" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="Gray"/>
            </StackPanel>
        </Grid>

        <!-- Steps + Log -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Steps -->
            <GroupBox Grid.Column="0" Header="Workflow steps">
                <ListView ItemsSource="{Binding Steps}" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Number}" Foreground="Gray"/>
                                <TextBlock Grid.Column="1" Text="{Binding Glyph}" Foreground="{Binding StatusBrush}" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontSize="10"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Log -->
            <GroupBox Grid.Column="2" Header="Log">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Clear" Width="70" Padding="4,2" Command="{Binding ClearLogCommand}"/>
                    </StackPanel>
                    <ListBox x:Name="LogList" ItemsSource="{Binding LogItems}"
                             FontFamily="Consolas" FontSize="11"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             VirtualizingStackPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}" TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>
        </Grid>

        <!-- Progress -->
        <Grid Grid.Row="3" Margin="0,10,0,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar Grid.Row="0" Height="20" Minimum="0" Maximum="100" Value="{Binding ProgressValue}"/>
            <TextBlock Grid.Row="1" Margin="0,4,0,0">
                <Run Text="{Binding StatusText, Mode=OneWay}" FontWeight="SemiBold"/>
                <Run Text="   "/>
                <Run Text="{Binding CurrentStepText, Mode=OneWay}" Foreground="Gray"/>
            </TextBlock>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Settings…" Width="100" Margin="0,0,8,0" Padding="6,4" Command="{Binding OpenSettingsCommand}"/>
            <Button Content="Reload settings" Width="120" Margin="0,0,8,0" Padding="6,4" Command="{Binding ReloadSettingsCommand}"/>
            <Button Content="Open output" Width="110" Margin="0,0,8,0" Padding="6,4" Command="{Binding OpenOutputFolderCommand}"/>
            <Button Content="Cancel" Width="100" Margin="0,0,8,0" Padding="6,4" Command="{Binding CancelCommand}"/>
            <Button Content="▶ Start" Width="140" Padding="6,4" FontWeight="Bold" Command="{Binding StartCommand}"/>
        </StackPanel>
    </Grid>
</Window>
